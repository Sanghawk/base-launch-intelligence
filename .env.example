# -----------------------------------------------------------------------------
# Local database
# -----------------------------------------------------------------------------
# Local Postgres from docker-compose.yml
DATABASE_URL=postgres://postgres:postgres@localhost:5432/base_launch_intel

# -----------------------------------------------------------------------------
# Worker configuration
# -----------------------------------------------------------------------------
# Real ingestion loop target cadence. M0 worker may still only run a placeholder loop.
WORKER_POLL_INTERVAL_MS=180000

# Max candidate launches/pairs to process per worker run.
WORKER_CANDIDATE_LIMIT=50

# -----------------------------------------------------------------------------
# Provider base URLs
# -----------------------------------------------------------------------------
# These are base URLs only. They are not secrets.
DEXSCREENER_BASE_URL=https://api.dexscreener.com
GECKOTERMINAL_BASE_URL=https://api.geckoterminal.com/api/v2
GOPLUS_BASE_URL=https://api.gopluslabs.io

# -----------------------------------------------------------------------------
# Optional provider credentials
# -----------------------------------------------------------------------------
# Leave empty for local M0. Do not commit real API keys.
BASESCAN_API_KEY=
BASE_RPC_URL=

# -----------------------------------------------------------------------------
# Optional provider feature flags
# -----------------------------------------------------------------------------
# Keep optional providers disabled by default for M0.
ENABLE_GECKOTERMINAL=false
ENABLE_BASESCAN=false
ENABLE_BASE_RPC=false
